# ── Claude AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Baserow (shared, tüm org'lar aynı tablo — org_id ile ayrışır) ──────────
BASEROW_API_URL=https://api.baserow.io
BASEROW_API_TOKEN=your_baserow_token_here
BASEROW_TABLE_ID=your_table_id_here

# ── Auth & Kriptografik Sırlar (PRODUCTION'da ZORUNLU, min 32 karakter, benzersiz) ──
# Çok-kullanıcılı auth: kullanıcılar data/users.json'da (scrypt hash, ilk açılışta tohumlanır).
# Parolalar: USER_PW_<USERNAME>=... ile siz belirleyebilirsiniz. Bırakırsanız ilk açılışta RASTGELE
# üretilip console'a yazılır (bir kez gösterilir, kaydedin).
# Admin parolası için APP_PASSWORD da kabul edilir (geriye dönük uyumluluk).
APP_PASSWORD=
# USER_PW_ADMIN=
# USER_PW_MEHMET_YILMAZ=
# USER_PW_DBADMIN=
# USER_PW_AHMET_SAHIN=
# USER_PW_ZEYNEP_KORKMAZ=
# USER_PW_MURAT_DEMIR=

# NODE_ENV=production iken zayıf/varsayılan/kısa (<32) sır → sunucu BAŞLAMAZ (checkSecrets).
# Oturum cookie imzası
SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars
# Audit log HASH ZİNCİRİ HMAC sırrı (yoksa SESSION_SECRET kullanılır). AYRI verilmesi önerilir.
CHAIN_SECRET=change_this_to_a_DIFFERENT_long_random_string_min_32
# WORM yedek AES-256-GCM anahtar türetimi (yoksa SESSION_SECRET). İdeali AYRI erişim alanında.
WORM_SECRET=change_this_to_a_THIRD_long_random_string_min_32chars

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Bildirim (n8n webhook → mail/Telegram) ───────────────────
# n8n webhook adresi. Kanal seçimi (mail/Telegram) n8n'de yapılır.
# n8n VPS üzerinde çalışıyor → kendi VPS adresinizi yazın (https önerilir).
N8N_NOTIFY_WEBHOOK_URL=https://n8n.SUNUCUNUZ.com/webhook/asset-alerts
# Zamanlanmış otomatik bildirim
NOTIFY_ENABLED=false
# Tarama aralığı (ms) — varsayılan 30 dk. Dedup sayesinde sık tarama spam yapmaz.
NOTIFY_INTERVAL_MS=1800000

# ── Cihaz Yaşam Döngüsü — Dijital Onay (sign-off) ────────────────
# Kritik durum değişikliğinde onaylayana giden onay linkinin geçerlilik süresi (ms).
# Süre dolunca pending → güvenlik ihlali. Varsayılan 24 saat. Demo için kısaltın (örn. 120000 = 2 dk).
APPROVAL_TTL_MS=86400000

# ── Plans (opsiyonel override) ────────────────────────────────
PLAN_STARTER_ASSET_LIMIT=50
PLAN_PRO_ASSET_LIMIT=500
PLAN_ENTERPRISE_ASSET_LIMIT=99999
