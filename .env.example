# ── Claude AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Baserow (shared, tüm org'lar aynı tablo — org_id ile ayrışır) ──────────
BASEROW_API_URL=https://api.baserow.io
BASEROW_API_TOKEN=your_baserow_token_here
BASEROW_TABLE_ID=your_table_id_here

# ── Auth & Kriptografik Sırlar (PRODUCTION'da ZORUNLU, min 32 karakter, benzersiz) ──
# Çok-kullanıcılı auth: kullanıcılar data/users.json'da (scrypt hash, ilk açılışta tohumlanır).
# Parolalar: USER_PW_<USERNAME>=... ile siz belirleyebilirsiniz. Bırakırsanız ilk açılışta RASTGELE
# üretilip console'a yazılır (bir kez gösterilir, kaydedin).
# Admin parolası için APP_PASSWORD da kabul edilir (geriye dönük uyumluluk).
APP_PASSWORD=
# USER_PW_ADMIN=
# USER_PW_MEHMET_YILMAZ=
# USER_PW_DBADMIN=
# USER_PW_AHMET_SAHIN=
# USER_PW_ZEYNEP_KORKMAZ=
# USER_PW_MURAT_DEMIR=

# NODE_ENV=production iken zayıf/varsayılan/kısa (<32) sır → sunucu BAŞLAMAZ (checkSecrets).
# Oturum cookie imzası
SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars
# Audit log HASH ZİNCİRİ HMAC sırrı (yoksa SESSION_SECRET kullanılır). AYRI verilmesi önerilir.
CHAIN_SECRET=change_this_to_a_DIFFERENT_long_random_string_min_32
# WORM yedek AES-256-GCM anahtar türetimi (yoksa SESSION_SECRET). İdeali AYRI erişim alanında.
WORM_SECRET=change_this_to_a_THIRD_long_random_string_min_32chars

# ── Veritabanı (SQLite | PostgreSQL — driver seçilebilir) ────────────
# Starter/tek sunucu için SQLite yeterli — sıfır ek servis, tek dosya.
# Pro/Enterprise için PostgreSQL — cluster/HA/DBA/PITR desteği.
#
# SQLite (varsayılan):
DATABASE_URL=sqlite:./data/assetman.db

# ── Envanter deposu (INVENTORY_PROVIDER=baserow | sql) ────────────────────────
# baserow (varsayılan): assets/licenses Baserow REST API'sinde.
# sql: assets/licenses yukarıdaki DATABASE_URL'de (Baserow'a bağımlılık YOK — veri kurumda kalır).
#   Geçiş: once `node scripts/migrate-inventory-to-sql.js` ile Baserow'dan taşı, sonra sql'e çevir.
INVENTORY_PROVIDER=baserow
#
# PostgreSQL (docker compose --profile postgres up ile):
# DATABASE_URL=postgres://assetman:${DB_PASSWORD}@db:5432/assetman
# DB_PASSWORD=guclu-bir-parola-min-32-karakter
# POSTGRES_DB=assetman
# POSTGRES_USER=assetman
#
# Baserow sayfa tavanı (getAllAssets binlerce cihaza sayfalayarak toplar)
BASEROW_MAX_PAGES=50

# ── Kimlik Sağlayıcı (AUTH_PROVIDER=local | ldap) ────────────────────
# local (varsayılan): kullanıcılar users tablosunda, scrypt parola. Sıfır ek servis.
# ldap: gerçek Active Directory bind. Kullanıcı ilk girişte dizinden users tablosuna
#   senkronlanır (rol = grup üyeliğinden). 'npm install ldapts' gerekir.
AUTH_PROVIDER=local
# ldap seçiliyse doldurun:
LDAP_URL=ldap://dc.sirket.local:389
# Kullanıcıyı aramak için servis (okuma) hesabı. Boşsa anonim arama denenir.
LDAP_BIND_DN=CN=svc-assetman,OU=ServiceAccounts,DC=sirket,DC=local
LDAP_BIND_PASSWORD=
# Arama kökü ve kullanıcı eşleşme attribute'u
LDAP_BASE_DN=DC=sirket,DC=local
LDAP_USER_ATTR=sAMAccountName
# {attr} ve {u} çalışma anında değiştirilir ({u} LDAP-escape edilir)
LDAP_USER_FILTER=(&(objectClass=user)({attr}={u}))
# AD grup CN'i → uygulama rolü (JSON). En yetkili rol kazanır. admin > approver > it
LDAP_GROUP_ROLE_MAP={"Domain Admins":"admin","BT Yönetimi":"admin","Onaylayanlar":"approver","BT Destek":"it"}
# Hiçbir gruba eşleşmezse verilecek varsayılan rol
LDAP_DEFAULT_ROLE=it
# MFA bu güvenlik grubu üyeliğiyle modellenir (Entra/Duo senkronu). Boşsa MFA üst
# katmanda zorunlu varsayılır (mfa_enabled=true).
LDAP_MFA_GROUP=
LDAP_TIMEOUT_MS=8000

# ── Döviz Kuru (FinOps bütçe motoru) ─────────────────────────
# live (varsayılan): frankfurter.app (ECB referans kuru, ücretsiz/anahtarsız). 60dk önbellek +
#   data/fx-cache.json'a yazar; API erişilemezse son bilinen kura, o da yoksa FX_BASE'e düşer.
# static: hiç dış istek yapmaz, sabit kuru kullanır (tam izole kapalı-devre kurulum için).
FX_PROVIDER=live
# FX_API_URL=https://api.frankfurter.app/latest?from=USD&to=TRY,EUR
# FX_CACHE_TTL_MS=3600000
# FX_TIMEOUT_MS=6000

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Docker / Reverse proxy (opsiyonel, docker-compose kullanıyorsanız) ──
# Public domain (Let's Encrypt otomatik cert için)
# ASSETMAN_HOST=envanter.sirket.com
# ADMIN_EMAIL=it@sirket.com
# Boş bırakırsanız Caddy self-signed / HTTP'de servis eder (LAN/dev).

# ── Bildirim (n8n webhook → mail/Telegram) ───────────────────
# n8n webhook adresi. Kanal seçimi (mail/Telegram) n8n'de yapılır.
# n8n VPS üzerinde çalışıyor → kendi VPS adresinizi yazın (https önerilir).
N8N_NOTIFY_WEBHOOK_URL=https://n8n.SUNUCUNUZ.com/webhook/asset-alerts
# Zamanlanmış otomatik bildirim
NOTIFY_ENABLED=false
# Tarama aralığı (ms) — varsayılan 30 dk. Dedup sayesinde sık tarama spam yapmaz.
NOTIFY_INTERVAL_MS=1800000

# ── Cihaz Yaşam Döngüsü — Dijital Onay (sign-off) ────────────────
# Kritik durum değişikliğinde onaylayana giden onay linkinin geçerlilik süresi (ms).
# Süre dolunca pending → güvenlik ihlali. Varsayılan 24 saat. Demo için kısaltın (örn. 120000 = 2 dk).
APPROVAL_TTL_MS=86400000

# ── Plans (opsiyonel override) ────────────────────────────────
PLAN_STARTER_ASSET_LIMIT=50
PLAN_PRO_ASSET_LIMIT=500
PLAN_ENTERPRISE_ASSET_LIMIT=99999
